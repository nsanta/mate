{
  "name": "@nsanta/mate",
  "type": "module",
  "scripts": {
    "build": "rolldown -c",
    "server": "node server/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run lint && npm run test -- --run && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "cors": "^2.8.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.1.0",
    "globals": "^15.15.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rolldown": "^1.0.0-beta.49",
    "svelte": "^5.55.9",
    "vitest": "^4.0.10",
    "vue": "^3.5.34"
  },
  "engines": {
    "node": ">=18"
  },
  "version": "0.0.9",
  "description": "A lightweight, HTMX-inspired library for declarative interactions.",
  "main": "dist/main.js",
  "exports": {
    ".": "./src/mate.js",
    "./mate.js": "./src/mate.js",
    "./react": "./src/react.js",
    "./vue": "./src/vue.js",
    "./svelte": "./src/svelte.js"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nsanta/mate.git"
  },
  "author": "Nicolas Santa",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nsanta/mate/issues"
  },
  "homepage": "https://github.com/nsanta/mate#readme"
}
